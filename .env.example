# HKUST SuperPod Auto - 配置文件
# 复制为 .env 并填入你的信息：cp .env.example .env

# ── 必填 ──
HKUST_USER=your-itsc-id@connect.ust.hk    # ITSC 账号
SUPERPOD_USER=your-itsc-id                  # SuperPod SSH 用户名
SUPERPOD_HOST=superpod.ust.hk               # SuperPod 主机名

# ── 代理 ──
CLASH_PORT=7897                             # 本地 Clash 代理端口
TUNNEL_PORT=17897                           # SuperPod 上的反向隧道端口

# ── 可选 ──
# VPN_SLICE_PATH=/path/to/vpn-slice        # vpn-slice 路径（默认自动检测）
# VPN_PROXY=http://127.0.0.1:7897          # VPN 登录时的代理（默认同 Clash）
# VPN_HOSTS=superpod.ust.hk                # 走 VPN 的主机（空格分隔多个）
