# HKUST SuperPod Auto - 配置文件
# 复制为 .env 并填入你的信息：cp .env.example .env
# 也可放在 ~/.config/spod/.env 供全局使用

# ── 必填 ──
HKUST_USER=your-itsc-id@connect.ust.hk
SUPERPOD_USER=your-itsc-id
SUPERPOD_HOST=superpod.ust.hk

# ── 代理 ──
CLASH_PORT=7897
SOCKS_PORT=1080
# TUNNEL_PORT 和 SPOD_RELAY_PORT 默认按远端 UID 自动分配，避免共享登录节点端口冲突。
# 仅在需要固定端口时才取消注释（会覆盖自动分配，多用户环境可能撞端口）：
# TUNNEL_PORT=17897
# SPOD_RELAY_PORT=18897

# ── 凭据 ──
HKUST_PASSWORD=your-password
HKUST_TOTP_SECRET=your-base32-totp-secret
SUDO_PASSWORD=your-sudo-password

# ── 可选 ──
# SPOD_SSH_HOST=superpod
# VPN_SLICE_PATH=/path/to/vpn-slice
# VPN_PROXY=http://127.0.0.1:7897
# VPN_HOSTS=superpod.ust.hk
